# Copy this file to .env and fill in values. Do not commit .env.

# News LLM: gemini | ollama (if unset: Gemini when GEMINI_API_KEY is set, otherwise Ollama)
# LLM_PROVIDER=ollama

# --- Gemini (optional) https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=models/gemini-2.0-flash

# --- Ollama (local, no API key) https://ollama.com
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
